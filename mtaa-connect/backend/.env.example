# ============================================
# MTAA CONNECT - BACKEND ENVIRONMENT CONFIG
# Copy this file to .env and fill your values
# ============================================

PORT=5000
NODE_ENV=development

# MongoDB Atlas - get free at mongodb.com/atlas
# Format: mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/mtaa_connect
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/mtaa_connect?retryWrites=true&w=majority

# JWT - change this to any long random string in production
JWT_SECRET=MtaaConnect_SuperSecret_Key_2024_ChangeInProduction!
JWT_EXPIRE=30d

# Frontend URL (for CORS) — set this to your Vercel deployment URL
# Example: https://mtaa-connection.vercel.app
FRONTEND_URL=https://mtaa-connection.vercel.app

# If you have a second Vercel URL (preview deploys), add it here
# FRONTEND_URL_PROD=https://mtaa-connect-git-main.vercel.app

# Cloudinary - optional, for image uploads (cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Africa's Talking - optional, for SMS (africastalking.com)
AT_API_KEY=your_at_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=MtaaConn

# M-Pesa Daraja - optional (developer.safaricom.co.ke)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/callback
MPESA_ENV=sandbox
